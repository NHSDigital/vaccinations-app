{
  "realm": "nhs-app-fake",
  "enabled": true,
  "clients": [
    {
      "clientId": "vita-app-sandpit",
      "enabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "clientAuthenticatorType": "client-jwt",
      "redirectUris": ["*"],
      "attributes": {
        "jwks.keys": "[{\"kty\":\"RSA\",\"n\":\"REPLACE_WITH_BASE64_ENCODED_PUBLIC_KEY_N\",\"e\":\"AQAB\"}]"
      }
    }
  ],
  "users": [
    {
      "username": "testuser-nhsapp",
      "enabled": true,
      "firstName": "Mandy",
      "lastName": "Carter",
      "email": "mandy@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "sausages",
          "temporary": false
        }
      ],
      "attributes": {
        "nhs_number": ["9686368973"]
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "nhs-login-broker",
      "displayName": "NHS Login",
      "providerId": "keycloak-oidc",
      "enabled": true,
      "trustEmail": true,
      "config": {
        "authorizationUrl": "http://localhost:3001/realms/nhs-login-fake/protocol/openid-connect/auth",
        "tokenUrl": "http://host.docker.internal:3001/realms/nhs-login-fake/protocol/openid-connect/token",
        "jwksUrl": "http://host.docker.internal:3001/realms/nhs-login-fake/protocol/openid-connect/certs",
        "clientId": "broker-client",
        "clientSecret": "broker-secret",
        "useJwksUrl": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "nhs-number-mapper",
      "identityProviderAlias": "nhs-login-broker",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "user.attribute": "nhs_number",
        "claim.name": "nhs_number",
        "syncMode": "FORCE"
      }
    }
  ]
}
